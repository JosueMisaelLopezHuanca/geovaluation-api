# Copia este archivo como .env y ajusta los valores locales.

# Base de datos local con docker-compose.yml
DATABASE_URL=postgresql+asyncpg://postgres:catastro_dev_password@127.0.0.1:5432/avalix_db
# En Supabase, incluir el esquema donde se habilito PostGIS: public,extensions o public,gis.
DATABASE_SEARCH_PATH=public

# Acceso administrador de desarrollo
CATASTRO_ADMIN_USER=admin
CATASTRO_ADMIN_PASSWORD=change-this-local-password
CATASTRO_AUTH_SECRET=change-me-before-production
CATASTRO_AUTH_TTL_MINUTES=240

# Dominio publico del frontend en beta. Separar varios con coma.
# Ejemplo: https://mi-geovisor.vercel.app,https://mi-geovisor.netlify.app
CORS_ALLOWED_ORIGINS=
CORS_ALLOW_LAN=true
